<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Base.Theme.AwStoredemo" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="colorPrimary">@color/primary</item>
        <item name="colorPrimaryVariant">@color/primary_variant</item>
        <item name="colorSecondary">@color/secondary</item>
        <item name="colorSecondaryVariant">@color/secondary_variant</item>
        <item name="android:colorBackground">@color/background</item>
        <item name="android:statusBarColor">@color/background</item>
        <item name="android:navigationBarColor">@color/surface</item>
        <item name="android:windowLightStatusBar">true</item>
    </style>

    <style name="Theme.AwStoredemo" parent="Base.Theme.AwStoredemo" />

    <style name="MaterialButton.AwStore" parent="Widget.Material3.Button">
        <item name="cornerRadius">12dp</item>
        <item name="android:paddingStart">16dp</item>
        <item name="android:paddingEnd">16dp</item>
        <item name="android:textSize">14sp</item>
    </style>

    <style name="MaterialButton.AwStore.Outlined" parent="Widget.Material3.Button.OutlinedButton">
        <item name="cornerRadius">12dp</item>
        <item name="android:paddingStart">16dp</item>
        <item name="android:paddingEnd">16dp</item>
        <item name="android:textSize">14sp</item>
        <item name="strokeColor">@color/primary</item>
        <item name="strokeWidth">1dp</item>
    </style>

    <style name="MaterialButton.AwStore.Text" parent="Widget.Material3.Button.TextButton">
        <item name="android:paddingStart">16dp</item>
        <item name="android:paddingEnd">16dp</item>
        <item name="android:textSize">14sp</item>
        <item name="android:textColor">@color/primary</item>
    </style>

    <style name="Card.AwStore" parent="Widget.MaterialComponents.CardView">
        <item name="cardCornerRadius">16dp</item>
        <item name="cardElevation">1dp</item>
        <item name="cardBackgroundColor">@color/card_background</item>
    </style>

    <style name="Text.AwStore" parent="TextAppearance.Material3.BodyMedium" />

    <style name="Text.AwStore.Title">
        <item name="android:textSize">20sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/on_surface</item>
    </style>

    <style name="Text.AwStore.Subtitle">
        <item name="android:textSize">16sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/on_surface</item>
    </style>

    <style name="Text.AwStore.Body">
        <item name="android:textSize">14sp</item>
        <item name="android:textColor">@color/on_surface_variant</item>
    </style>

    <style name="Toolbar.AwStore" parent="Widget.Material3.Toolbar">
        <item name="titleTextColor">@color/on_background</item>
        <item name="android:background">@color/background</item>
    </style>

    <style name="Text.AwStore.Log">
        <item name="android:textSize">12sp</item>
        <item name="android:textColor">@color/log_text</item>
        <item name="android:fontFamily">monospace</item>
    </style>
</resources>